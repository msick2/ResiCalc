<UserControl x:Class="_260328_ResiCalc.VoltDividerUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F0F2F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── 입력 ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                           Text="전압 분배 저항 계산기"
                           FontSize="16" FontWeight="Bold" Foreground="#1A237E"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="입력 전압 (Vin)"  Style="{StaticResource Lbl}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtVin"  Style="{StaticResource In}" KeyDown="Input_KeyDown"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="V" Style="{StaticResource Lbl}" HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="출력 전압 (Vout)" Style="{StaticResource Lbl}"/>
                <TextBox   Grid.Row="4" Grid.Column="1" x:Name="txtVout" Style="{StaticResource In}" KeyDown="Input_KeyDown"/>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="V" Style="{StaticResource Lbl}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="4" Grid.Column="3" x:Name="lblRatio"
                           Style="{StaticResource Lbl}" Margin="8,0,0,0" FontSize="12" Foreground="#90A4AE"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="저항 계열" Style="{StaticResource Lbl}"/>
                <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal">
                    <RadioButton x:Name="rbE24"  Content="E24"  IsChecked="True"/>
                    <RadioButton x:Name="rbE96"  Content="E96"/>
                    <RadioButton x:Name="rbE192" Content="E192"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 버튼 + 수식 ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="계산하기" Style="{StaticResource CalcBtn}" Click="Calc_Click"/>
            <TextBlock Grid.Column="1" x:Name="lblFormula"
                       Foreground="#607D8B" FontSize="12" FontFamily="Consolas"
                       VerticalAlignment="Center" Margin="14,0,0,0"/>
        </Grid>

        <!-- ── 결과 ── -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="추천 저항 조합" FontSize="13" FontWeight="SemiBold" Foreground="#37474F"/>
                    <TextBlock x:Name="lblCount" Foreground="#90A4AE" FontSize="12"
                               Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>

                <DataGrid Grid.Row="2" x:Name="dgResult"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECEFF1"
                          HeadersVisibility="Column" ColumnHeaderStyle="{StaticResource ColHdr}"
                          CellStyle="{StaticResource CellStyle}"
                          AlternatingRowBackground="#FAFAFA" RowBackground="White"
                          BorderThickness="0" RowHeaderWidth="0" RowHeight="34"
                          CanUserResizeRows="False" CanUserReorderColumns="False"
                          SelectionMode="Single" FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"        Binding="{Binding Rank}"       Width="38">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CT}">
                                    <Setter Property="Foreground" Value="#90A4AE"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="R1"       Binding="{Binding R1}"         Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CT}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="R2"       Binding="{Binding R2}"         Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CT}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="실제 Vout" Binding="{Binding ActualVout}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CT}"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="오차"     Binding="{Binding Error}"      Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CT}"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="합성 저항" Binding="{Binding TotalR}"    Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CT}">
                                    <Setter Property="Foreground" Value="#78909C"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
