<UserControl x:Class="_260328_ResiCalc.BuckConverterUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F0F2F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── 입력 ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="6"
                           Text="벅 컨버터 인덕턴스 계산기"
                           FontSize="16" FontWeight="Bold" Foreground="#1A237E"/>

                <!-- 왼쪽 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="입력 전압 (Vin)"  Style="{StaticResource Lbl}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtVin"  Style="{StaticResource In}" KeyDown="Input_KeyDown"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="V" Style="{StaticResource Lbl}" HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="출력 전압 (Vout)" Style="{StaticResource Lbl}"/>
                <TextBox   Grid.Row="4" Grid.Column="1" x:Name="txtVout" Style="{StaticResource In}" KeyDown="Input_KeyDown"/>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="V" Style="{StaticResource Lbl}" HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="출력 전류 (Iout)" Style="{StaticResource Lbl}"/>
                <TextBox   Grid.Row="6" Grid.Column="1" x:Name="txtIout" Style="{StaticResource In}" KeyDown="Input_KeyDown"/>
                <TextBlock Grid.Row="6" Grid.Column="2" Text="A" Style="{StaticResource Lbl}" HorizontalAlignment="Center"/>

                <!-- 오른쪽 -->
                <TextBlock Grid.Row="2" Grid.Column="3" Text="스위칭 주파수 (f)"  Style="{StaticResource Lbl}"/>
                <TextBox   Grid.Row="2" Grid.Column="4" x:Name="txtFreq" Style="{StaticResource In}" KeyDown="Input_KeyDown"/>
                <TextBlock Grid.Row="2" Grid.Column="5" Text="kHz" Style="{StaticResource Lbl}" Margin="4,0,0,0"/>

                <TextBlock Grid.Row="4" Grid.Column="3" Text="전류 리플 비율 (r)" Style="{StaticResource Lbl}"/>
                <TextBox   Grid.Row="4" Grid.Column="4" x:Name="txtRipple" Text="30" Style="{StaticResource In}" KeyDown="Input_KeyDown"/>
                <TextBlock Grid.Row="4" Grid.Column="5" Text="% (20~40 권장)" Style="{StaticResource Lbl}" Margin="4,0,0,0" FontSize="11"/>
            </Grid>
        </Border>

        <!-- ── 버튼 ── -->
        <Button Grid.Row="2" Content="계산하기" Style="{StaticResource CalcBtn}"
                HorizontalAlignment="Left" Click="Calc_Click"/>

        <!-- ── 결과 ── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌: 주요 계산값 -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16">
                <StackPanel>
                    <TextBlock Text="계산 결과" FontSize="13" FontWeight="SemiBold"
                               Foreground="#37474F" Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="듀티 사이클 (D)"      Style="{StaticResource Lbl}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtRD"               FontWeight="SemiBold" VerticalAlignment="Center" FontSize="14"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="최소 인덕턴스 (Lmin)" Style="{StaticResource Lbl}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtRLmin"            FontWeight="Bold" VerticalAlignment="Center" FontSize="14" Foreground="#1A237E"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="리플 전류 (ΔIL)"      Style="{StaticResource Lbl}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtRDeltaIL"         FontWeight="SemiBold" VerticalAlignment="Center" FontSize="14"/>

                        <Separator Grid.Row="3" Grid.ColumnSpan="2" Background="#ECEFF1"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="피크 전류 (IL_peak)"  Style="{StaticResource Lbl}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtRILpeak"          FontWeight="SemiBold" VerticalAlignment="Center" FontSize="14" Foreground="#B71C1C"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="RMS 전류 (IL_rms)"    Style="{StaticResource Lbl}"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtRILrms"           FontWeight="SemiBold" VerticalAlignment="Center" FontSize="14"/>

                        <Separator Grid.Row="6" Grid.ColumnSpan="2" Background="#ECEFF1"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="평균 입력 전류 (Iin)" Style="{StaticResource Lbl}"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="txtRIin"             FontWeight="SemiBold" VerticalAlignment="Center" FontSize="14"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 우: E12 표준 인덕터 추천 -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="E12 표준 인덕터 추천" FontSize="13" FontWeight="SemiBold" Foreground="#37474F"/>
                        <TextBlock x:Name="lblLmin" Foreground="#90A4AE" FontSize="11"
                                   Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2" x:Name="dgInductor"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECEFF1"
                              HeadersVisibility="Column" ColumnHeaderStyle="{StaticResource ColHdr}"
                              CellStyle="{StaticResource CellStyle}"
                              AlternatingRowBackground="#FAFAFA" RowBackground="White"
                              BorderThickness="0" RowHeaderWidth="0" RowHeight="32"
                              CanUserResizeRows="False" CanUserReorderColumns="False"
                              SelectionMode="Single" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="인덕턴스" Binding="{Binding L}"       Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CT}">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="모드"     Binding="{Binding Mode}"    Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CT}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="ΔIL"     Binding="{Binding DeltaIL}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CT}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="IL_peak" Binding="{Binding ILpeak}"  Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CT}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="비고"     Binding="{Binding Note}"    Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CT}">
                                        <Setter Property="Foreground" Value="#1565C0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
